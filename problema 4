#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int x, y, c;
    scanf("%d %d %d", &x, &y, &c);

    int q;
    if (x > 0 && y > 0) q = 1;
    else if (x < 0 && y > 0) q = 2;
    else if (x < 0 && y < 0) q = 3;
    else if (x > 0 && y < 0) q = 4;
    else {
        printf("caminhada invalida\n");
        return 0;
    }

    int dest_x, dest_y;
    int adj1, adj2;

    if (q == 1) { dest_x = -1; dest_y = -1; adj1 = 2; adj2 = 4; }
    else if (q == 2) { dest_x =  1; dest_y = -1; adj1 = 1; adj2 = 3; }
    else if (q == 3) { dest_x =  1; dest_y =  1; adj1 = 2; adj2 = 4; }
    else             { dest_x = -1; dest_y =  1; adj1 = 1; adj2 = 3; }

    if (c != adj1 && c != adj2) {
        printf("caminhada invalida\n");
        return 0;
    }

    int steps_x = x - dest_x;
    if (steps_x < 0) steps_x = -steps_x;

    int steps_y = y - dest_y;
    if (steps_y < 0) steps_y = -steps_y;

    int y_primeiro = 0;

    if (q == 1) {
        if (c == 2) y_primeiro = 1;
        else        y_primeiro = 0;
    } else if (q == 2) {
        if (c == 1) y_primeiro = 1;
        else        y_primeiro = 0;
    } else if (q == 3) {
        if (c == 4) y_primeiro = 1;
        else        y_primeiro = 0;
    } else {
        if (c == 3) y_primeiro = 1;
        else        y_primeiro = 0;
    }

    if (y_primeiro) {
        printf("%d passos em y e %d passos em x\n", steps_y, steps_x);
    } else {
        printf("%d passos em x e %d passos em y\n", steps_x, steps_y);
    }

    return 0;
}
